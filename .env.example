# --- LLM Provider ---
# "openai" = direct OpenAI API key  |  "azure_kong" = Azure OpenAI via Kong Gateway
LLM_PROVIDER=openai

# --- OpenAI (used when LLM_PROVIDER=openai) ---
OPENAI_API_KEY=
# MODEL_NAME=gpt-4o
# EMBEDDING_MODEL=text-embedding-3-small

# --- Kong Gateway / Azure OpenAI (used when LLM_PROVIDER=azure_kong) ---
# KONG_CLIENT_ID=
# KONG_CLIENT_SECRET=
# KONG_BASE_URL=
# KONG_DEPLOYMENT=gpt-4o
# KONG_MINI_DEPLOYMENT=gpt-4o-mini
# KONG_EMBEDDING_DEPLOYMENT=text-embedding-3-small
# KONG_API_VERSION=2025-01-01-preview
# FEDERATION_URL=
# KONG_VERIFY_SSL=true

# --- PostgreSQL ---
DATABASE_HOSTNAME=localhost
DATABASE_PORT=5432
DATABASE_NAME=postgres

# Read-write user -- used EXCLUSIVELY by the running app at runtime
DATABASE_RW_USER=
DATABASE_RW_PASSWORD=

# Admin user -- used EXCLUSIVELY for DDL (Alembic migrations, ensure_schema.py,
#   setup_checkpointer.py, grant_rw_privileges.py). Never deployed to production.
DATABASE_ADMIN_USER=
DATABASE_ADMIN_PASSWORD=

DB_SCHEMA=public

# --- Other ---
TAVILY_API_KEY=
