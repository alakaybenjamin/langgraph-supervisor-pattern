# --- LLM Provider ---
# "openai" = direct OpenAI API key  |  "azure_kong" = Azure OpenAI via Kong Gateway
LLM_PROVIDER=openai

# --- OpenAI (used when LLM_PROVIDER=openai) ---
OPENAI_API_KEY=
# MODEL_NAME=gpt-4o
# EMBEDDING_MODEL=text-embedding-3-small

# --- Kong Gateway / Azure OpenAI (used when LLM_PROVIDER=azure_kong) ---
# KONG_CLIENT_ID=
# KONG_CLIENT_SECRET=
# KONG_BASE_URL=
# KONG_DEPLOYMENT=gpt-4o
# KONG_MINI_DEPLOYMENT=gpt-4o-mini
# KONG_EMBEDDING_DEPLOYMENT=text-embedding-3-small
# KONG_API_VERSION=2025-01-01-preview
# FEDERATION_URL=
# KONG_VERIFY_SSL=true

# --- PostgreSQL ---
DATABASE_HOSTNAME=localhost
DATABASE_PORT=5432
DATABASE_NAME=postgres
# Read-write user -- used by the running app
DATABASE_USER=
DATABASE_PASSWORD=
DB_SCHEMA=public
# Admin user -- DDL only (ensure_schema, setup_checkpointer, grant_rw_privileges), not used at runtime
# DATABASE_ADMIN_USER=
# DATABASE_ADMIN_PASSWORD=

# --- Other ---
TAVILY_API_KEY=
